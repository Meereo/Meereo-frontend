# ─────────────────────────────────────────
#  MEEREO SERVER — Variables d'environnement
#  Copiez ce fichier en .env et remplissez les valeurs
# ─────────────────────────────────────────

# PostgreSQL — URL de connexion Prisma
DATABASE_URL="postgresql://meereo:meereo2026@localhost:5432/meereo?schema=public"

# JWT
JWT_SECRET=change-me-in-production-must-be-at-least-32-chars
JWT_EXPIRES_IN=30d

# Bcrypt
BCRYPT_ROUNDS=12

# Serveur
PORT=3001
NODE_ENV=development

# CORS — origine du frontend (dev)
ALLOWED_ORIGIN=http://localhost:5173

# Password reset — durée de validité du lien (en minutes)
RESET_TOKEN_EXPIRES_MIN=60
