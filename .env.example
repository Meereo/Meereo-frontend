# ─────────────────────────────────────────
#  MEEREO — Variables d'environnement
#  Copiez ce fichier en .env et remplissez les valeurs
# ─────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=meereo
POSTGRES_PASSWORD=meereo2026
POSTGRES_DB=meereo

# MinIO (stockage fichiers)
MINIO_ACCESS_KEY=meereo
MINIO_SECRET_KEY=meereo2026
MINIO_BUCKET=meereo-files

# JWT
JWT_SECRET=change-me-in-production-32chars-min

# Anthropic (KAI assistant)
ANTHROPIC_API_KEY=sk-ant-...

# URLs
FRONTEND_URL=http://localhost
ALLOWED_ORIGIN=http://localhost

# Build-time (Vite) — laisser vide pour utiliser le proxy nginx
VITE_API_URL=/api
